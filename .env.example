# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=core_hub_db

# Django Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Security
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this

# Monitoring
GF_SECURITY_ADMIN_PASSWORD=your-grafana-admin-password

# Frontend Environment Variables
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_public_razorpay_key
NEXT_PUBLIC_RAZORPAY_PLAN_WEBCAM_MO=plan_webcam_mo_id
NEXT_PUBLIC_RAZORPAY_PLAN_WEBCAM_QTR=plan_webcam_qtr_id
NEXT_PUBLIC_RAZORPAY_PLAN_WEBCAM_YR=plan_webcam_yr_id
NEXT_PUBLIC_RAZORPAY_PLAN_HEALTH_MO=plan_health_mo_id
NEXT_PUBLIC_RAZORPAY_PLAN_HEALTH_QTR=plan_health_qtr_id
NEXT_PUBLIC_RAZORPAY_PLAN_HEALTH_YR=plan_health_yr_id
NEXT_PUBLIC_RAZORPAY_PLAN_COMBO_MO=plan_combo_mo_id
NEXT_PUBLIC_RAZORPAY_PLAN_COMBO_QTR=plan_combo_qtr_id
NEXT_PUBLIC_RAZORPAY_PLAN_COMBO_YR=plan_combo_yr_id
NEXT_PUBLIC_RAZORPAY_PLAN_BUSINESS=plan_business_id
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
